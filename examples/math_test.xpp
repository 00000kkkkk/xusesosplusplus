// Test file for xuesos test runner
xuen test_add() {
    assert_eq(2 + 2, 4)
    assert_eq(10 + 20, 30)
}

xuen test_fibonacci() {
    xuen fib(n int) int {
        xuif (n <= 1) { xueturn n }
        xueturn fib(n - 1) + fib(n - 2)
    }
    assert_eq(fib(10), 55)
}

xuen main() {
    test_add()
    test_fibonacci()
    print("All tests passed!")
}

{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Xuesos++",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#characters" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#functions" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.xuesos",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.xuesos",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.xuesos",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.xuesos",
                            "match": "\\\\."
                        },
                        {
                            "name": "meta.interpolation.xuesos",
                            "begin": "\\{",
                            "end": "\\}",
                            "patterns": [
                                { "include": "$self" }
                            ]
                        }
                    ]
                }
            ]
        },
        "characters": {
            "patterns": [
                {
                    "name": "string.quoted.single.xuesos",
                    "match": "'(?:\\\\.|[^'])'"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.xuesos",
                    "match": "\\b(xuif|xuelse|xuior|xuile|xuin|xuieak|xuitinue|xueturn|xuiatch|xutry|xucatch|xuthrow)\\b"
                },
                {
                    "name": "keyword.declaration.xuesos",
                    "match": "\\b(xuen|xuet|xuiar|xuiruct|xuimpl|xuenum|xuimport|xuiub)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.xuesos",
                    "match": "\\b(int|int8|int16|int32|int64|uint|float|float32|bool|str|char|byte)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.xuesos",
                    "match": "\\b(xuitru|xuinia|xuinull)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.xuesos",
                    "match": "\\b0[xX][0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.xuesos",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.xuesos",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.float.xuesos",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.xuesos",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.xuesos",
                    "match": "(=>|\\.\\.|\\.|\\.\\.|&&|\\|\\||==|!=|<=|>=|[+\\-*/%<>!=])"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.xuesos",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                }
            ]
        }
    },
    "scopeName": "source.xuesos"
}
